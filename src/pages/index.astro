---
import DestinationCard from "../components/DestinationCard.astro";
import PhotoSlots from "../components/PhotoSlots.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { destinations, journalPrompts, siteConfig } from "../data/destinations";
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <main>
    <section class="site-shell hero">
      <div>
        <p class="eyebrow">Travel Journal / Photo Atlas</p>
        <h1>把世界装进一座私人地图。</h1>
        <p class="lead">
          这里会慢慢收纳我在不同国家旅行时拍下的照片、城市路线、餐桌记忆和一些不太像攻略的随笔。先从柏林开始，之后每到一个地方，就给它留下一页光。
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#destinations">查看目的地</a>
          <a class="button secondary" href="#photo-slots">我要补照片</a>
        </div>
      </div>

      <div class="hero-card" aria-label="旅行照片拼贴">
        <div class="photo-stack">
          <figure class="polaroid one">
            <img src="/assets/images/travel-hero-editorial.png" alt="旅行拼贴视觉" />
          </figure>
          <figure class="polaroid two">
            <img src="/assets/images/berlin-cover-editorial.png" alt="柏林封面视觉" />
          </figure>
        </div>
        <aside class="trip-note">
          <strong>Next stop?</strong>
          <span>把下一组照片放进 <code>public/assets/photos/国家-城市/</code>，再更新 <code>src/data/destinations.ts</code>。</span>
        </aside>
      </div>
    </section>

    <section class="site-shell section" id="story">
      <div class="bento">
        <article class="panel story-panel">
          <div class="story-media">
            <img src="/assets/images/berlin-cover-editorial.png" alt="柏林旅行视觉" />
          </div>
          <div class="story-copy">
            <div>
              <p class="eyebrow">Featured Story</p>
              <h2>柏林：在旧城和新光之间散步。</h2>
              <p class="lead">
                穹顶、河岸、街角咖啡和电车轨道。柏林不急着解释自己，它更像一本被翻旧的书，等你把每一页都走成自己的路线。
              </p>
              <div class="meta-row">
                <span class="pill">Germany</span>
                <span class="pill">Architecture</span>
                <span class="pill">Slow Walk</span>
              </div>
            </div>
            <a class="button secondary" href="/berlin/">进入柏林相册</a>
          </div>
        </article>
        <aside class="stat-grid">
          <div class="panel stat">
            <strong>12+</strong>
            <span>预留国家/城市章节，可持续扩展。</span>
          </div>
          <div class="panel stat">
            <strong>3</strong>
            <span>推荐内容结构：路线、照片、短文。</span>
          </div>
        </aside>
      </div>
    </section>

    <section class="site-shell section" id="destinations">
      <div class="section-header">
        <div>
          <p class="eyebrow">Destinations</p>
          <h2>目的地</h2>
        </div>
        <p>每个国家或城市都可以拥有自己的封面、相册、路线和故事。现在已有柏林首版，其余位置先用占位图承接。</p>
      </div>
      <div class="destination-grid">
        {destinations.map((destination) => <DestinationCard destination={destination} />)}
      </div>
    </section>

    <section class="site-shell section">
      <article class="panel quote-band">
        <p>旅行不是为了证明去过哪里，而是把某个瞬间保存成以后还能再次进入的房间。</p>
      </article>
    </section>

    <section class="site-shell section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Writing System</p>
          <h2>文案模板</h2>
        </div>
        <p>以后每篇旅行内容都可以按这三个角度写，既有照片，也有个人记忆。</p>
      </div>
      <div class="journal-grid">
        {
          journalPrompts.map((prompt) => (
            <article class="journal-card">
              <p class="eyebrow">{prompt.kicker}</p>
              <h3>{prompt.title}</h3>
              <p>{prompt.copy}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="site-shell section" id="photo-slots">
      <div class="placeholder-dropzone">
        <p class="eyebrow">Photo Slots</p>
        <h2>给未来照片留好的位置</h2>
        <p class="lead">
          建议把真实照片统一放在 <code>public/assets/photos/国家-城市/</code>。下面是推荐文件名，后续只要在 <code>src/data/destinations.ts</code> 里替换图片路径即可。
        </p>
        <PhotoSlots />
      </div>
    </section>
  </main>
</BaseLayout>
