---
import { siteConfig } from "../data/destinations";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const normalize = (path: string) => path.replace(/\/$/, "") || "/";
const current = normalize(currentPath);
const links = [
  { href: "/", label: "首页" },
  { href: "/berlin/", label: "柏林" },
  { href: "/shanghai/", label: "上海" },
  { href: "/about/", label: "关于" },
  { href: "/services/", label: "整理方法" },
  { href: "/contact/", label: "联系" },
];
---

<header class="site-header">
  <div class="site-shell nav">
    <a class="brand" href="/" aria-label="Walter Mitty home">
      <span class="brand-mark">WM</span>
      <span>{siteConfig.name}</span>
    </a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">菜单</button>
    <nav class="nav-links" id="site-nav" aria-label="主导航">
      {
        links.map((link) => (
          <a href={link.href} aria-current={normalize(link.href) === current ? "page" : undefined}>
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const links = document.querySelector(".nav-links");

  toggle?.addEventListener("click", () => {
    const isOpen = links?.classList.toggle("is-open") ?? false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>
